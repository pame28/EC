CREATE OR ALTER PROCEDURE dbo.usp_ConsultarEstadoCuenta
(
    @NoTarjeta VARCHAR(16),
    @FechaCorte DATE
)
AS
BEGIN

SET NOCOUNT ON;

DECLARE @NoCuenta VARCHAR(13)

SELECT TOP 1
    @NoCuenta = NoCuenta
FROM BandejaEncabezado
WHERE NoTarjeta = @NoTarjeta
AND FechaCorte = @FechaCorte


DECLARE @Estado NVARCHAR(10)

SELECT TOP 1
    @Estado = EstadoTarjeta
FROM Tarjetas
WHERE NumeroTarjeta = @NoTarjeta


-------------------------------------------------
-- ENCABEZADO
-------------------------------------------------

SELECT
    hc.Origen,
    hc.Emisor,
    hc.NoCuenta,
    hc.NombreTHTit,
    hc.EmisorMadre,
    hc.CuentaMadre,
    hc.NombreEmpresa,
    hc.TipoTarjeta,
    hc.NoTarjeta,

    CONVERT(VARCHAR(10),hc.FechaPago,103) FechaPago,
    CONVERT(VARCHAR(10),hc.FechaCorte,103) FechaCorte,

    hc.PagoContadoMN,
    hc.PagoMinimoMN,
    hc.SaldoVencidoMN,
    hc.SaldoAnteriorMN,
    hc.SaldoFinalMN,

    hc.ComprasDebMN,
    hc.PagosCredMN,
    hc.SobregiroMN,
    hc.CuotaMesMN,

    hc.PagoContadoME,
    hc.PagoMinimoME,
    hc.SaldoVencidoME,
    hc.SaldoAnteriorME,
    hc.SaldoFinalME,

    ISNULL(
        hc.ComprasDebMN
        - hc.InteresCorrienteMN
        + hc.SaldoAnteriorMN
        - hc.PagosCredMN,
    0) SaldoConsumoMN,

    ISNULL(
        hc.ComprasDebME
        - hc.InteresCorrienteME
        + hc.SaldoAnteriorME
        - hc.PagosCredME,
    0) SaldoConsumoME,

    hc.LimiteCredito,
    hc.DisponibleCtaMN,
    hc.DisponibleCtaME,

    hc.PTSSaldoAnt,
    hc.PTSGanados,
    hc.PTSUsuados,
    hc.PTSSaldoActual,

    hc.Direccion1,
    hc.Direccion2,
    hc.Direccion3,

    hc.Cidudad,

    hc.Mensaje1,
    hc.Mensaje2,
    hc.Mensaje3,
    hc.Mensaje4,
    hc.Mensaje5,

    hc.Correo,

    @Estado Estado

FROM BandejaEncabezado hc
WHERE hc.NoCuenta = @NoCuenta
AND hc.FechaCorte = @FechaCorte


-------------------------------------------------
-- DETALLE
-------------------------------------------------

SELECT
    d.ECDetalleNoCuenta AS NoCuenta,
    d.ECDetalleNoTarjeta AS NoTarjeta,
    d.NoAutorizacion,

    CONVERT(VARCHAR(10),d.FechaCorte,103) FechaCorte,
    CONVERT(VARCHAR(10),d.FechaConsumo,103) FechaConsumo,

    1 TipoReg,

    d.DescripcionMov,

    CASE
        WHEN d.MonedaMov='HN'
        AND tm.TipoMovimiento='D'
        THEN d.MontoMov
        ELSE 0
    END DebitosMN,

    CASE
        WHEN d.MonedaMov='HN'
        AND tm.TipoMovimiento='C'
        THEN d.MontoMov
        ELSE 0
    END CreditosMN,

    CASE
        WHEN d.MonedaMov='DO'
        AND tm.TipoMovimiento='D'
        THEN d.MontoMov
        ELSE 0
    END DebitosME,

    CASE
        WHEN d.MonedaMov='DO'
        AND tm.TipoMovimiento='C'
        THEN d.MontoMov
        ELSE 0
    END CreditosME

FROM BandejaDetalle d

JOIN TiposMovimientos tm
ON tm.CodMovimiento = d.CodigoMov

WHERE d.ECDetalleNoCuenta = @NoCuenta
AND d.FechaCorte = @FechaCorte

ORDER BY d.FechaConsumo


-------------------------------------------------
-- FINANCIAMIENTOS
-------------------------------------------------

SELECT
    CASE
        WHEN EsIntra = 1 THEN 'Intrafinanciamientos'
        ELSE 'Extrafinanciamientos'
    END Tipo,

    CONVERT(VARCHAR(10),FechaOtorgamiento,103) Fecha,

    ImporteTotalPlan Monto,
    MonedaMovimiento Moneda,
    Importe Cuota,
    CantidadCuotasPlan Plazo,
    NoCuotaLiquidada CuotaAplicada,

    CONCAT(CAST(PlanExtraTasa AS DECIMAL(10,2)),'%') Tasa,

    PlanCuotaCapitalPend Saldo

FROM BandejaFinanciamientos

WHERE NumeroCuenta = @NoCuenta
AND FechaCierre = @FechaCorte
AND PlanCuotaCapitalPend > 0

END