CREATE PROCEDURE [dbo].[usp_LlenarBandejas]
-- =============================================
-- Author:		Pamela N. Suazo
-- Create date: 11/03/2026
-- Description:	Limpia y llena las bandejas de información de Estados de Cuenta por fecha de carga (cada corte)
-- =============================================
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @FechaCorte DATE = (SELECT TOP(1) FechaCorte FROM ParametrosCorte WHERE Estado='1');
    DECLARE @Reproceso INT = (SELECT COUNT(1) FROM BandejaEstadoCuenta WHERE Estado='2');

    BEGIN TRY
        BEGIN TRANSACTION;

        -- Limpiar bandejas principales
        IF OBJECT_ID('dbo.BandejaEncabezado', 'U') IS NOT NULL TRUNCATE TABLE dbo.BandejaEncabezado;
        IF OBJECT_ID('dbo.BandejaDetalle', 'U') IS NOT NULL TRUNCATE TABLE dbo.BandejaDetalle;
        IF OBJECT_ID('dbo.BandejaFinanciamientos', 'U') IS NOT NULL TRUNCATE TABLE dbo.BandejaFinanciamientos;

        -- Llenar bandeja encabezado
        INSERT INTO dbo.BandejaEncabezado
        SELECT *
        FROM dbo.EstadoCuentaEncabezado
        WHERE FechaCorte = @FechaCorte;

        -- Llenar bandeja detalle
        INSERT INTO dbo.BandejaDetalle
        SELECT *
        FROM dbo.EstadoCuentaDetalle
        WHERE FechaCorte = @FechaCorte;

        -- Llenar bandeja financiamientos
        INSERT INTO dbo.BandejaFinanciamientos
        SELECT *
        FROM dbo.EstadoCuentaFinanciamientos
        WHERE FechaCierre = @FechaCorte;

        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;

        DECLARE @ErrorMsg NVARCHAR(4000) = ERROR_MESSAGE();
        DECLARE @ErrorNum INT = ERROR_NUMBER();

        RAISERROR('Error %d: %s', 16, 1, @ErrorNum, @ErrorMsg);
    END CATCH
END
GO






