CREATE PROCEDURE dbo.usp_LlenarBandejaEstadoCuenta
AS
BEGIN

SET NOCOUNT ON;

DECLARE @Cantidad INT
DECLARE @FechaCorte DATE

SELECT @Cantidad = COUNT(*)
FROM dbo.BandejaEstadoCuenta

SELECT @FechaCorte = FechaCorte
FROM [dbo].[ParametrosCorte]
WHERE Estado = 1


IF (@Cantidad < 1)
BEGIN

    INSERT INTO dbo.BandejaEstadoCuenta
    (
        FechaCorte,
        NoTarjeta,
        NoCuenta,
        Correo,
        Estado
    )

    SELECT
        h.FechaCorte,
        TRIM(h.NoTarjeta),
        TRIM(h.NoCuenta),
        TRIM(h.Correo),
        2
    FROM dbo.BandejaEncabezado h

    INNER JOIN dbo.FechaCarga fc
        ON h.Origen = fc.Origen

    WHERE
        h.FechaCorte = @FechaCorte

        AND h.Correo <> ''

        AND h.Correo NOT IN
        (
            SELECT Correo
            FROM dbo.CorreosNoValidos
            WHERE Estado = 1
        )

        AND
        (
            EXISTS
            (
                SELECT 1
                FROM dbo.BandejaDetalle d
                WHERE d.ECDetalleNoCuenta = h.NoCuenta
                AND d.FechaCorte = h.FechaCorte
            )
            OR h.PagoContadoMN <> 0
            OR h.PagoContadoME <> 0
        )

END

END
