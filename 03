ALTER PROCEDURE  [dbo].[usp_LlenaBandejasEstadoCuenta]
-- =============================================
-- Author:		henrry M .Padilla
-- Create date: 27/06/2022
-- Description:	Limpia y llena las bandejas de información de estados de cuenta por fecha de carga (cada corte)
-- =============================================
AS
BEGIN

DECLARE @FechaCorte as date = (Select FechaCorte from Param_IS_ECTC Where Estado='1'),
		@Reproceso INT= (SELECT COUNT(1) FROM BandejaECTC WHERE Estado=2);

	--IF(@Reproceso<1)
	--BEGIN
	--Limpiar badejas
		Truncate Table [BPTarjetas].[dbo].[HEstadoCuenta_BandejaEnvioTC]
		Truncate Table [BPTarjetas].[dbo].[DEstadoCuenta_BandejaEnvioTC] 
		Truncate Table [BPTarjetas].[dbo].[Financiamientos_BandejaEnvioTC]

	--llenar bandejas

		Insert into  [BPTarjetas].[dbo].[HEstadoCuenta_BandejaEnvioTC]
		Select * from [BPTarjetas].[dbo].HEstadoCuenta Where Fecha_Corte=@FechaCorte --And No_Tarjeta='1000000003294902'
	
		Insert into [BPTarjetas].[dbo].[DEstadoCuenta_BandejaEnvioTC]
		Select * from [BPTarjetas].[dbo].[DEstadoCuenta] Where Fecha_Corte=@FechaCorte --And EC_DetalleNo_Tarjeta='1000000003294902'
	
		Insert into [BPTarjetas].[dbo].[Financiamientos_BandejaEnvioTC]
		SELECT * FROM [BPTarjetas].[dbo].[Financiamientos] WHERE FechaCierre=@FechaCorte --And NumeroCuenta='5000001656764'
	--END
END




