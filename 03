    a.DescripcionMov,
    CASE WHEN a.MonedaMov='HN' AND b.TipoMovimiento='D' THEN a.MontoMov ELSE 0 END DebitosMN,
    CASE WHEN a.MonedaMov='HN' AND b.TipoMovimiento='C' THEN a.MontoMov ELSE 0 END CreditosMN,
    CASE WHEN a.MonedaMov='DO' AND b.TipoMovimiento='D' THEN a.MontoMov ELSE 0 END DebitosME,
    CASE WHEN a.MonedaMov='DO' AND b.TipoMovimiento='C' THEN a.MontoMov ELSE 0 END CreditosME
FROM BandejaDetalle a
JOIN TiposMovimientos b
ON b.CodMovimiento=a.CodigoMov
WHERE a.ECDetalleNoCuenta=hc.NoCuenta
AND a.FechaCorte=hc.FechaCorte

UNION ALL

SELECT
    a.FechaCorte,
    3,
    'Total Titular + Adicional',
    SUM(CASE WHEN a.MonedaMov='HN' AND b.TipoMovimiento='D' THEN a.MontoMov ELSE 0 END),
    SUM(CASE WHEN a.MonedaMov='HN' AND b.TipoMovimiento='C' THEN a.MontoMov ELSE 0 END),
    SUM(CASE WHEN a.MonedaMov='DO' AND b.TipoMovimiento='D' THEN a.MontoMov ELSE 0 END),
    SUM(CASE WHEN a.MonedaMov='DO' AND b.TipoMovimiento='C' THEN a.MontoMov ELSE 0 END)

FROM BandejaDetalle a
JOIN TiposMovimientos b
ON b.CodMovimiento=a.CodigoMov

WHERE a.ECDetalleNoCuenta=hc.NoCuenta
AND a.FechaCorte=hc.FechaCorte

GROUP BY a.ECDetalleNoCuenta,a.FechaCorte

) d

ORDER BY d.FechaConsumo,d.TipoReg

FOR JSON PATH
)
) AS Detalle,


JSON_QUERY(
(
SELECT
    Tipo,
    Fecha,
    Monto,
    Moneda,
    Cuota,
    Plazo,
    CuotaAplicada,
    Tasa,
    Saldo
FROM
(
SELECT
    'Intrafinanciamientos' Tipo,
    f.FechaOtorgamiento Fecha,
    f.ImporteTotalPlan Monto,
    f.MonedaMovimiento Moneda,
    f.Importe Cuota,
    f.CantidadCuotasPlan Plazo,
    f.NoCuotaLiquidada CuotaAplicada,
    f.PlanExtraTasa Tasa,
    f.PlanCuotaCapitalPend Saldo
FROM BandejaFinanciamientos f
WHERE f.NumeroCuenta=hc.NoCuenta
AND f.FechaCierre=hc.FechaCorte
AND f.PlanCuotaCapitalPend>0
AND f.EsIntra=1

UNION ALL

SELECT
    'Extrafinanciamientos',
    f.FechaOtorgamiento,
    f.ImporteTotalPlan,
    f.MonedaMovimiento,
    f.Importe,
    f.CantidadCuotasPlan,
    f.NoCuotaLiquidada,
    f.PlanExtraTasa,
    f.PlanCuotaCapitalPend
FROM BandejaFinanciamientos f
WHERE f.NumeroCuenta=hc.NoCuenta
AND f.FechaCierre=hc.FechaCorte
AND f.PlanCuotaCapitalPend>0
AND f.EsExtra=1
) f

FOR JSON PATH
)
) AS Financiamientos

FOR JSON PATH, WITHOUT_ARRAY_WRAPPER

)

FROM BandejaEncabezado hc

LEFT JOIN CuentasArregloPagos ecap
ON hc.NoCuentaClaro=ecap.NumeroCuenta
AND ecap.FechaCorte=hc.FechaCorte

LEFT JOIN HistoricoVASATC.dbo.MensajeArregloPagos map
ON map.idMensaje=ecap.idMensaje

WHERE hc.FechaCorte=@FechaCorte
AND hc.NoTarjeta IN (SELECT NoTarjeta FROM tcEstados)


SELECT COUNT(*) AS Cantidad
FROM BandejaEstadoCuentaJson

END




