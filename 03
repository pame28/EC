CREATE OR ALTER PROCEDURE dbo.usp_LlenarBandejaECTCJson
AS
BEGIN

SET NOCOUNT ON;

DECLARE @FechaCorte DATE

SELECT @FechaCorte = FechaCorte
FROM Param_IS_ECTC
WHERE Estado = 1


TRUNCATE TABLE dbo.BandejaECTCJson


;WITH tcEstados AS
(
    SELECT
        et.NumeroTarjeta AS No_Tarjeta,
        CONVERT(VARCHAR, ISNULL(et.EstadoTarjeta,0)) AS Estado
    FROM ETarjetas et
    WHERE CONVERT(VARCHAR(10),et.FechaCarga,103)+et.NumeroTarjeta IN
    (
        SELECT CONVERT(VARCHAR(10),MAX(etfc.FechaCarga),103)+etfc.NumeroTarjeta
        FROM ETarjetas etfc
        WHERE etfc.NumeroTarjeta IN (SELECT No_Tarjeta FROM BandejaECTC)
        GROUP BY etfc.NumeroTarjeta
    )
)

INSERT INTO dbo.BandejaECTCJson
(
    Fecha_Corte,
    No_Tarjeta,
    No_Cuenta,
    Correo,
    Estado,
    Json
)

SELECT
    hc.Fecha_Corte,
    hc.No_Tarjeta,
    hc.No_Cuenta,
    hc.Correo,
    '2',

(
SELECT

hc.No_Tarjeta,

JSON_QUERY(
(
SELECT
    hc.Origen,
    hc.Emisor,
    hc.No_Cuenta,
    hc.Nombre_TH_Tit,
    hc.Emisor_Madre,
    hc.Cuenta_Madre,
    hc.Nombre_Empresa,
    hc.Tipo_Tarjeta,
    hc.No_Tarjeta,
    hc.Fecha_Pago,
    hc.Fecha_Corte,
    hc.Pago_Contado_MN,
    hc.Pago_Minimo_MN,
    hc.Saldo_Vencido_MN,
    hc.Saldo_Anterior_MN,
    hc.Saldo_Final_MN,
    hc.Compras_Deb_MN,
    hc.Pagos_Cred_MN,
    hc.Sobregiro_MN,
    hc.Cuota_Mes_MN,
    hc.Pago_Contado_ME,
    hc.Pago_Minimo_ME,
    hc.Saldo_Vencido_ME,
    hc.Saldo_Anterior_ME,
    hc.Saldo_Final_ME,
    hc.Compras_Deb_ME,
    hc.Pagos_Cred_ME,
    hc.Sobregiro_ME,
    hc.Cuota_Mes_ME,
    hc.Moneda_Lim_Cre,
    hc.Limite_Credito,
    hc.Disponible_Cta_MN,
    hc.Disponible_Cta_ME,
    hc.Disponible_Ret_MN,
    hc.Disponible_Ret_ME,
    hc.PTS_Saldo_Ant,
    hc.PTS_Ganados,
    hc.PTS_Usuados,
    hc.PTS_Saldo_Actual,
    hc.Moneda_Lim_EF,
    hc.EF_Limite,
    hc.EF_Saldo_MN,
    hc.EF_Debitos_MN,
    hc.EF_Creditos_MN,
    hc.EF_Saldo_ME,
    hc.EF_Debitos_ME,
    hc.EF_Creditos_ME,
    hc.EF_Disponible_MN,
    hc.EF_Disponible_ME,
    hc.Tasa_Int_Anual_MN,
    hc.Tasa_Int_Anual_ME,
    hc.Direccion_1,
    hc.Direccion_2,
    hc.Direccion_3,
    hc.Apdo_Postal,
    hc.Cidudad,
    map.Mensaje AS Mensaje_1,
    hc.Mensaje_2,
    hc.Mensaje_3,
    hc.Mensaje_4,
    hc.Mensaje_5,
    hc.Tarjeta_Imprimir,
    hc.Costo_Anual_Tot_MN,
    hc.Costo_Anual_Tot_ME,
    hc.Plazo_Canc_Deuda_MN,
    hc.Plazo_Canc_Deuda_ME,
    hc.Interes_Pago_Min_MN,
    hc.Interes_Pago_Min_ME,
    hc.Correo,
    hc.Limite_CreditoMN,
    hc.Interes_Corriente_MN,
    hc.Interes_Corriente_ME,
    (SELECT Estado FROM tcEstados t WHERE t.No_Tarjeta = hc.No_Tarjeta) AS Estado
FOR JSON PATH, WITHOUT_ARRAY_WRAPPER
)
) AS Encabezado,


JSON_QUERY(
(
SELECT

d.Fecha_Consumo,
d.Tipo_Reg,
d.Descripcion_Mov,
d.DebitosMN,
d.CreditosMN,
d.DebitosME,
d.CreditosME

FROM
(
SELECT
    a.Fecha_Consumo,
    1 AS Tipo_Reg,
    a.Descripcion_Mov,
    CASE WHEN a.Moneda_Mov='HN' AND b.TipoMovimiento='D' THEN a.Monto_Mov ELSE 0 END DebitosMN,
    CASE WHEN a.Moneda_Mov='HN' AND b.TipoMovimiento='C' THEN a.Monto_Mov ELSE 0 END CreditosMN,
    CASE WHEN a.Moneda_Mov='DO' AND b.TipoMovimiento='D' THEN a.Monto_Mov ELSE 0 END DebitosME,
    CASE WHEN a.Moneda_Mov='DO' AND b.TipoMovimiento='C' THEN a.Monto_Mov ELSE 0 END CreditosME
FROM EC_Detalle_Envio_Estado_Correo a
JOIN TiposMovimientos b
ON b.CodMovimiento=a.Codigo_Mov
WHERE a.EC_DetalleNo_Cuenta=hc.No_Cuenta
AND a.Fecha_Corte=hc.Fecha_Corte

UNION ALL

SELECT
    a.Fecha_Corte,
    3,
    'Total Titular + Adicional',
    SUM(CASE WHEN a.Moneda_Mov='HN' AND b.TipoMovimiento='D' THEN a.Monto_Mov ELSE 0 END),
    SUM(CASE WHEN a.Moneda_Mov='HN' AND b.TipoMovimiento='C' THEN a.Monto_Mov ELSE 0 END),
    SUM(CASE WHEN a.Moneda_Mov='DO' AND b.TipoMovimiento='D' THEN a.Monto_Mov ELSE 0 END),
    SUM(CASE WHEN a.Moneda_Mov='DO' AND b.TipoMovimiento='C' THEN a.Monto_Mov ELSE 0 END)

FROM EC_Detalle_Envio_Estado_Correo a
JOIN TiposMovimientos b
ON b.CodMovimiento=a.Codigo_Mov

WHERE a.EC_DetalleNo_Cuenta=hc.No_Cuenta
AND a.Fecha_Corte=hc.Fecha_Corte

GROUP BY a.EC_DetalleNo_Cuenta,a.Fecha_Corte

) d

ORDER BY d.Fecha_Consumo,d.Tipo_Reg

FOR JSON PATH
)
) AS Detalle,


JSON_QUERY(
(
SELECT
    Tipo,
    Fecha,
    Monto,
    Moneda,
    Cuota,
    Plazo,
    CuotaAplicada,
    Tasa,
    Saldo
FROM
(
SELECT
    'Intrafinanciamientos' Tipo,
    f.FechaOtorgamiento Fecha,
    f.ImporteTotalPlan Monto,
    f.MonedaMovimiento Moneda,
    f.Importe Cuota,
    f.CantidadCuotasPlan Plazo,
    f.NoCuotaLiquidada CuotaAplicada,
    f.PlanExtraTasa Tasa,
    f.PlanCuotaCapitalPend Saldo
FROM Financiamientos_BandejaEnvioTC f
WHERE f.NumeroCuenta=hc.No_Cuenta
AND f.FechaCierre=hc.Fecha_Corte
AND f.PlanCuotaCapitalPend>0
AND f.EsIntra=1

UNION ALL

SELECT
    'Extrafinanciamientos',
    f.FechaOtorgamiento,
    f.ImporteTotalPlan,
    f.MonedaMovimiento,
    f.Importe,
    f.CantidadCuotasPlan,
    f.NoCuotaLiquidada,
    f.PlanExtraTasa,
    f.PlanCuotaCapitalPend
FROM Financiamientos_BandejaEnvioTC f
WHERE f.NumeroCuenta=hc.No_Cuenta
AND f.FechaCierre=hc.Fecha_Corte
AND f.PlanCuotaCapitalPend>0
AND f.EsExtra=1
) f

FOR JSON PATH
)
) AS Financiamientos

FOR JSON PATH, WITHOUT_ARRAY_WRAPPER

)

FROM HEstadoCuenta_BandejaEnvioTC hc

LEFT JOIN EC_CuentasArregloPagos ecap
ON hc.NoCuentaClaro=ecap.NumeroCuenta
AND ecap.FechaCorte=hc.Fecha_Corte

LEFT JOIN HistoricoVASATC.dbo.MensajeArregloPagos map
ON map.idMensaje=ecap.idMensaje

WHERE hc.Fecha_Corte=@FechaCorte
AND hc.No_Tarjeta IN (SELECT No_Tarjeta FROM tcEstados)


SELECT COUNT(*) AS Cantidad
FROM BandejaECTCJson

END