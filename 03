CREATE TABLE dbo.ConfiguracionEstadoCuenta
(
    Id INT PRIMARY KEY,

    PlantillaEncabezado TEXT,
    PlantillaDetalleHeader TEXT,
    PlantillaDetalleMovimiento TEXT,
    PlantillaDetalleFooter TEXT,

    PlantillaFinanciamientoHeader TEXT,
    PlantillaFinanciamientoMovimiento TEXT,
    PlantillaFinanciamientoFooter TEXT,

    PlantillaMensaje TEXT,

    QueryPrincipal VARCHAR(MAX),

    Ambiente VARCHAR(10),

    QueryCorreosInvalidos TEXT,

    QueryConteo TEXT,

    DireccionReporte VARCHAR(MAX),

    RutaArchivoJson VARCHAR(200),

    RutaArchivoHistoricoJson VARCHAR(200),

    LlaveProceso VARCHAR(100)
)












CREATE PROCEDURE dbo.usp_ObtenerConfiguracionEstadoCuenta
AS
BEGIN

SET NOCOUNT ON;

DECLARE @FechaCorte DATE

SELECT @FechaCorte = FechaCorte
FROM dbo.ParametrosCorte
WHERE Estado = 1


SELECT 
    QueryPrincipal AS QueryRegistros,

    'SELECT COUNT(*) FROM BandejaEstadoCuenta WHERE Estado=2' AS QueryConteo,

    RutaArchivoJson,

    RutaArchivoHistoricoJson,

    @FechaCorte AS FechaCorte,

    LlaveProceso,

    'LOTE' AS TipoGeneracion,

    100000 AS CantidadEjecucion,

    20 AS CantidadLotes,

    'SELECT CEILING(((SELECT COUNT(*) FROM BandejaEstadoCuenta WHERE Estado=2)*1.0)/20)' AS QueryRegistrosPorLote

FROM dbo.ConfiguracionEstadoCuenta
WHERE Id = 1

END