# =========================
# BUILD STAGE
# =========================
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src

# Instalar dependencias necesarias y certificados
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates \
        unixodbc \
        unixodbc-dev \
        libltdl7 \
        wget \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copiar paquete IBM iAccess
COPY ibm-iaccess-1.1.0.28-1.0.amd64.deb /tmp/

# Instalar IBM iAccess
RUN dpkg -i /tmp/ibm-iaccess-1.1.0.28-1.0.amd64.deb || apt-get install -f -y

# Copiar el resto del proyecto
COPY . .

# Restaurar paquetes NuGet
RUN dotnet restore

# Publicar aplicación
RUN dotnet publish -c Release -o /app/publish

# =========================
# RUNTIME STAGE
# =========================
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final

WORKDIR /app

# Instalar dependencias runtime necesarias
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates \
        unixodbc \
        libltdl7 \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Configurar variable de entorno ODBC
ENV LD_LIBRARY_PATH=/opt/ibm/iaccess/lib

# Copiar IBM iAccess desde el build
COPY --from=build /opt/ibm /opt/ibm

# Copiar aplicación publicada
COPY --from=build /app/publish .

# Mantener entrypoint original
ENTRYPOINT ["dotnet", "reposicion_pin.dll"]