# =========================
# BUILD STAGE
# =========================
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copiar solo archivos necesarios para restore
COPY *.csproj ./
COPY nuget.config ./

# Agregar certificado proxy (si aplica)
COPY proxy-root.crt /usr/local/share/ca-certificates/
RUN update-ca-certificates

# Probar acceso a NuGet.org
RUN curl -I https://api.nuget.org/v3/index.json || echo "❌ No hay acceso a NuGet.org"

# Restaurar paquetes NuGet
RUN dotnet restore

# Instalar dependencias necesarias
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      unixodbc unixodbc-dev libltdl7 dpkg ca-certificates wget curl && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Copiar paquete IBM iAccess y el resto del código
COPY ibm-iaccess-1.1.0.28-1.0.amd64.deb /tmp/
COPY . .

# Instalar IBM iAccess y dependencias rotas
RUN if [ -f /tmp/ibm-iaccess-1.1.0.28-1.0.amd64.deb ]; then \
      dpkg -i /tmp/ibm-iaccess-1.1.0.28-1.0.amd64.deb || true && \
      apt-get update && \
      DEBIAN_FRONTEND=noninteractive apt-get -y --fix-broken install; \
    fi && \
    rm -rf /tmp/ibm-iaccess-1.1.0.28-1.0.amd64.deb /var/lib/apt/lists/*

# Configurar variable de entorno para linter y ODBC
ARG LD_LIBRARY_PATH
ENV LD_LIBRARY_PATH=/opt/ibm/iaccess/lib64:${LD_LIBRARY_PATH}

# Publicar la aplicación
RUN dotnet publish -c Release -o /app/publish

# =========================
# RUNTIME STAGE
# =========================
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app

# Copiar aplicación publicada
COPY --from=build /app/publish .

# Copiar snapshot ODBC
COPY --from=build /odbc-snapshot/lib /opt/odbc/lib
COPY --from=build /odbc-snapshot/bin /opt/odbc/bin
COPY --from=build /odbc-snapshot/etc /opt/odbc/etc
COPY --from=build /odbc-snapshot/iaccess /opt/ibm/iaccess

# Permisos para OpenShift
RUN chmod -R a+r /opt/odbc && \
    chmod -R a+rx /opt/odbc/bin && \
    chmod -R a+r /opt/ibm

# Configuración ODBC
RUN mkdir -p /opt/odbc && \
    if [ -f /opt/odbc/etc/odbcinst.ini ]; then \
      cp /opt/odbc/etc/odbcinst.ini /opt/odbc/odbcinst.ini; \
    else \
      printf '%s\n' '[iSeries Access ODBC Driver]' \
        'Description=IBM i Access for Linux ODBC Driver' \
        'Driver=/opt/ibm/iaccess/lib64/libcwbodbc.so' \
        'FileUsage=1' > /opt/odbc/odbcinst.ini; \
    fi

# Actualizar cache de librerías
RUN echo "/opt/odbc/lib" > /etc/ld.so.conf.d/odbc.conf && ldconfig

# Variables de entorno ODBC
ENV LD_LIBRARY_PATH=/opt/odbc/lib64:/opt/ibm/iaccess/lib64:$LD_LIBRARY_PATH
ENV ODBCSYSINI=/opt/odbc
ENV ODBCINI=/opt/odbc/odbc.ini

# Registrar driver si odbcinst está disponible
RUN if [ -x /opt/odbc/bin/odbcinst ]; then \
      /opt/odbc/bin/odbcinst -i -d -f /opt/odbc/odbcinst.ini || true; \
    fi

ENTRYPOINT ["dotnet", "Criptografia.dll"]