ALTER PROCEDURE [dbo].[usp_SBEstadoCuenta]
-- Add the parameters for the stored procedure here
	@Equivalente VARCHAR(16),
	@FechaCorte date
AS
BEGIN
	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;
	
	DECLARE @No_Cuenta AS VARCHAR(13)
	DECLARE @NumeroEquivalente AS VARCHAR(16)
	IF(@Equivalente NOT LIKE '10%')
	BEGIN
		SELECT @NumeroEquivalente = et.Equivalencia
		  FROM BandejaATH.dbo.EquivalenciasTarjetas et
		WHERE BandejaATH.dbo.ufn_Hashing(@Equivalente) = et.NumeroTarjetaHash
		
		IF(@NumeroEquivalente IS NOT NULL)
		BEGIN
			SET @Equivalente = @NumeroEquivalente
		END
	END


	;with cte
	as
	(
		select  NoUsuario No_Cuenta
			FROM  dbo.ETarjetas
			--WHERE ModeloLiquidacion <> '999'
			where NumeroTarjeta = @Equivalente
		union all 
		select distinct No_Cuenta 
			from HEstadoCuenta_BandejaEnvioTC
			where No_Tarjeta = @Equivalente
			and Origen in ('ATH')
	)
		SELECT 
			@No_Cuenta =  No_Cuenta
			FROM HEstadoCuenta_BandejaEnvioTC hc
			WHERE exists (select 1 from cte where cte.No_Cuenta = hc.No_Cuenta)
			and Fecha_Corte = @FechaCorte

			      

	       
	--Agregado
	DECLARE @Estado NVARCHAR(10)
	SELECT TOP 1 @Estado = e.EstadoTarjeta
	FROM dbo.ETarjetas e
	WHERE e.NumeroTarjeta = @Equivalente
	
	--Encabezado
		SELECT hc.Origen,
		       hc.Emisor,
		       hc.No_Cuenta,
		       hc.Nombre_TH_Tit,
		       hc.Emisor_Madre,
		       hc.Cuenta_Madre,
		       hc.Nombre_Empresa,
		       hc.Tipo_Tarjeta,
		       --produc.Producto Descripcion_Tipo_Tarjeta,
		       hc.No_Tarjeta,
		       CONVERT(VARCHAR(10), hc.Fecha_Pago, 103) Fecha_Pago,
		       CONVERT(VARCHAR(10), hc.Fecha_Corte, 103) Fecha_Corte,
		       hc.Pago_Contado_MN,
		       hc.Pago_Minimo_MN,
		       hc.Saldo_Vencido_MN,
		       hc.Saldo_Anterior_MN,
		       hc.Saldo_Final_MN,
		       hc.Compras_Deb_MN,
		       hc.Pagos_Cred_MN,
		       hc.Sobregiro_MN,
		       hc.Cuota_Mes_MN,
		       hc.Pago_Contado_ME,
		       hc.Pago_Minimo_ME,
		       hc.Saldo_Vencido_ME,
		       hc.Saldo_Anterior_ME,
		       hc.Saldo_Final_ME,
		       ISNULL(
		           (
		               hc.Compras_Deb_MN - hc.Interes_Corriente_MN + hc.Saldo_Anterior_MN 
		               - hc.Pagos_Cred_MN
		           ),
		           0
		       )               Saldo_Consumo_MN,
		       ISNULL(
		           (
		               hc.Compras_Deb_ME - hc.Interes_Corriente_ME + hc.Saldo_Anterior_ME 
		               - hc.Pagos_Cred_ME
		           ),
		           0
		       )               Saldo_Consumo_ME,
		       hc.Compras_Deb_ME,
		       hc.Pagos_Cred_ME,
		       hc.Sobregiro_ME,
		       hc.Cuota_Mes_ME,
		       hc.Moneda_Lim_Cre,
		       hc.Limite_Credito,
		       hc.Disponible_Cta_MN,
		       hc.Disponible_Cta_ME,
		       hc.Disponible_Ret_MN,
		       hc.Disponible_Ret_ME,
		       CAST(hc.PTS_Saldo_Ant AS BIGINT) PTS_Saldo_Ant,
		       CAST(hc.PTS_Ganados AS BIGINT) PTS_Ganados,
		       CAST(hc.PTS_Usuados AS BIGINT) PTS_Usuados,
		       CAST(hc.PTS_Saldo_Actual AS BIGINT) PTS_Saldo_Actual,
		       hc.Moneda_Lim_EF,
		       hc.EF_Limite,
		       hc.EF_Saldo_MN,
		       hc.EF_Debitos_MN,
		       hc.EF_Creditos_MN,
		       hc.EF_Saldo_ME,
		       hc.EF_Debitos_ME,
		       hc.EF_Creditos_ME,
		       hc.EF_Disponible_MN,
		       hc.EF_Disponible_ME,
		       hc.Tasa_Int_Anual_MN,
		       hc.Tasa_Int_Anual_ME,
		       hc.Direccion_1,
		       hc.Direccion_2,
		       hc.Direccion_3,
		       hc.Apdo_Postal,
		       hc.Cidudad
		       --,hc.Mensaje_1
		       ,
		      isnull(map.Mensaje,'')     Mensaje_1,
			   
		       hc.Mensaje_2,
		       hc.Mensaje_3,
		       hc.Mensaje_4,
		       hc.Mensaje_5,
		       hc.Tarjeta_Imprimir,
		       hc.Costo_Anual_Tot_MN,
		       hc.Costo_Anual_Tot_ME,
		       hc.Plazo_Canc_Deuda_MN,
		       hc.Plazo_Canc_Deuda_ME,
		       hc.Interes_Pago_Min_MN,
		       hc.Interes_Pago_Min_ME,
		       hc.Correo,
		       ISNULL(hc.Limite_CreditoMN, 0)Limite_CreditoMN,
		       ISNULL(hc.Interes_Corriente_MN, 0)Interes_Corriente_MN,
		       ISNULL(hc.Interes_Corriente_ME, 0)Interes_Corriente_ME,
		       @Estado         Estado 
		       --FROM   HEstadoCuenta_BandejaEnvioTC hc
		FROM   HEstadoCuenta_BandejaEnvioTC hc
		       LEFT JOIN EC_CuentasArregloPagos ecap
		            ON  hc.NoCuentaClaro = ecap.NumeroCuenta
		            AND ecap.FechaCorte = @FechaCorte
		       LEFT JOIN HistoricoVASATC.dbo.MensajeArregloPagos map
		       --LEFT JOIN MensajeArregloPagos map solo es la leyenda
		            ON  map.idMensaje = ecap.idMensaje
		       --LEFT JOIN P_Producto produc
		       --     ON  rtrim(ltrim(produc.codProducto))=rtrim(ltrim(hc.Tipo_Tarjeta))
		WHERE  hc.Fecha_Corte = @FechaCorte
		       AND hc.No_Cuenta = @No_Cuenta
			   --and exists ( SELECT * FROM DEstadoCuenta_BandejaEnvioTC dx WHERE dx.NoCuentaClaro = hc.No_Cuenta AND dx.Fecha_Corte = hc.Fecha_Corte)
	
	
	--Detalle
		SELECT D.No_Cuenta
				,D.No_Tarjeta
				,D.No_Autorizacion
				,CONVERT(VARCHAR(10),D.Fecha_Corte, 103) Fecha_Corte 
				,CONVERT(VARCHAR(10),D.Fecha_Consumo, 103) Fecha_Consumo 
				,D.Tipo_Reg
				,D.Descripcion_Mov
				,D.DebitosMN
				,D.CreditosMN
				,D.DebitosME
				,D.CreditosME				
		  FROM (
			
			--Movimientos
			SELECT
			   LTrim(RTrim(a.EC_DetalleNo_Cuenta)) No_Cuenta
			   ,a.EC_DetalleNo_Tarjeta No_Tarjeta
			   ,LTrim(RTrim(a.No_Autorizacion)) No_Autorizacion
			   ,a.Fecha_Corte
			   ,a.Fecha_Consumo
			   ,1 Tipo_Reg
			   ,LTrim(RTrim(a.Descripcion_Mov)) Descripcion_Mov
			   ,CASE WHEN a.Moneda_Mov = 'HN' AND b.TipoMovimiento = 'D' THEN a.Monto_Mov ELSE 0 END As DebitosMN
			   ,CASE WHEN a.Moneda_Mov = 'HN' AND b.TipoMovimiento = 'C' THEN a.Monto_Mov ELSE 0 END As CreditosMN
			   ,CASE WHEN a.Moneda_Mov = 'DO' AND b.TipoMovimiento = 'D' THEN a.Monto_Mov ELSE 0 END As DebitosME
			   ,CASE WHEN a.Moneda_Mov = 'DO' AND b.TipoMovimiento = 'C' THEN a.Monto_Mov ELSE 0 END As CreditosME	
			 			   
			From
				dbo.EC_Detalle_Envio_Estado_Correo a
			INNER JOIN dbo.TiposMovimientos b
				ON b.CodMovimiento = a.Codigo_Mov
			WHERE a.Fecha_Corte = @FechaCorte
			AND a.EC_DetalleNo_Cuenta = @No_Cuenta
			
		--Subtotales
		UNION ALL

			Select
				LTrim(RTrim(a.EC_DetalleNo_Cuenta)) No_Cuenta
			   ,a.EC_DetalleNo_Tarjeta No_Tarjeta
			   ,'' No_Autorizacion
			   ,a.Fecha_Corte
			   ,a.Fecha_Corte Fecha_Consumo
			   ,2 Tipo_Reg
			   ,'Subtotal ' + LTrim(RTrim(a.Nombre_TH_P)) + ' ' + '******' +
				a.Tarjeta_Imprimir Descripcion_Mov
			   ,SUM(CASE WHEN a.Moneda_Mov = 'HN' And b.TipoMovimiento = 'D' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) DebitosMN
			   ,SUM(CASE WHEN a.Moneda_Mov = 'HN' And b.TipoMovimiento = 'C' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) CreditosMN
			   ,SUM(CASE WHEN a.Moneda_Mov = 'DO' And b.TipoMovimiento = 'D' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) DebitosME
			   ,SUM(CASE WHEN a.Moneda_Mov = 'DO' And b.TipoMovimiento = 'C' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) CreditosME
			  
			From
				dbo.EC_Detalle_Envio_Estado_Correo a
			INNER JOIN dbo.TiposMovimientos b
				ON b.CodMovimiento = a.Codigo_Mov
			WHERE a.Fecha_Corte = @FechaCorte
				AND a.EC_DetalleNo_Cuenta = @No_Cuenta
			Group By
				a.Codigo_Emisor
			   ,a.EC_DetalleNo_Cuenta
			   ,a.EC_DetalleNo_Tarjeta
			   ,a.Fecha_Corte
			   ,a.Nombre_TH_P
			   ,Tarjeta_Imprimir 

		UNION ALL
		 
		--Totales
			Select
				LTrim(RTrim(a.EC_DetalleNo_Cuenta)) No_Cuenta
			   ,'90000000000000000' No_Tarjeta
			   ,'' No_Autorizacion
			   ,a.Fecha_Corte
			   ,a.Fecha_Corte Fecha_Consumo
			   ,3 Tipo_Reg
			   ,'Total Titular + Adicional' Descripcion_Mov
			   ,SUM(CASE WHEN a.Moneda_Mov = 'HN' And b.TipoMovimiento = 'D' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) DebitosMN
			   ,SUM(CASE WHEN a.Moneda_Mov = 'HN' And b.TipoMovimiento = 'C' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) CreditosMN
			   ,SUM(CASE WHEN a.Moneda_Mov = 'DO' And b.TipoMovimiento = 'D' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) DebitosME
			   ,SUM(CASE WHEN a.Moneda_Mov = 'DO' And b.TipoMovimiento = 'C' And LTrim(RTrim(b.ClaseMovimiento)) <> 'MP' THEN a.Monto_Mov ELSE 0 END) CreditosME			
			From
				dbo.EC_Detalle_Envio_Estado_Correo a
			INNER JOIN dbo.TiposMovimientos b
				ON b.CodMovimiento = a.Codigo_Mov
			WHERE a.Fecha_Corte = @FechaCorte
			AND a.EC_DetalleNo_Cuenta = @No_Cuenta
			Group By
			   a.EC_DetalleNo_Cuenta
			   ,a.Fecha_Corte
			 
		  )D
		ORDER BY D.No_Cuenta, D.No_Tarjeta, D.Fecha_Consumo, D.Tipo_Reg

	--Financiamientos

		SELECT 'Intrafinanciamientos' Tipo
			  ,convert(varchar(10), f.FechaOtorgamiento, 103) Fecha
		      ,f.ImporteTotalPlan Monto
		      ,f.MonedaMovimiento  Moneda
		      ,f.Importe Cuota
		      ,f.CantidadCuotasPlan Plazo
		      ,f.NoCuotaLiquidada CuotaAplicada
		      ,case when f.PlanExtraTasa = 0 then '0%' else rtrim(cast(cast(f.PlanExtraTasa as numeric(10,2)) as char(10))) + '%' END Tasa
		      ,f.PlanCuotaCapitalPend Saldo
		FROM   Financiamientos_BandejaEnvioTC f
		WHERE  f.NumeroCuenta = @No_Cuenta
		       AND f.FechaCierre = @FechaCorte
		       AND f.PlanCuotaCapitalPend > 0
		       AND f.EsIntra = 1
		UNION ALL
		
		SELECT 'Extrafinanciamientos' Tipo 
			  ,convert(varchar(10),f.FechaOtorgamiento,103) Fecha
		      ,f.ImporteTotalPlan  Monto
		      ,f.MonedaMovimiento Moneda
		      ,f.Importe Cuota
		      ,f.CantidadCuotasPlan Plazo
		      ,f.NoCuotaLiquidada CuotaAplicada
		       ,case when f.PlanExtraTasa = 0 then '0%' else rtrim(cast(cast(f.PlanExtraTasa as numeric(10,2)) as char(10))) + '%' END Tasa
		      ,f.PlanCuotaCapitalPend Saldo
		FROM   Financiamientos_BandejaEnvioTC f
		WHERE  f.NumeroCuenta = @No_Cuenta
		       AND f.FechaCierre = @FechaCorte
		       AND f.PlanCuotaCapitalPend > 0
		       AND f.EsExtra = 1
	
	  
END



