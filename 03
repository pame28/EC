            EXISTS
            (
                SELECT 1
                FROM dbo.BandejaDetalle d
                WHERE d.ECDetalleNoCuenta = h.NoCuenta
                AND d.FechaCorte = h.FechaCorte
            )
            OR h.PagoContadoMN <> 0
            OR h.PagoContadoME <> 0
        )

END

END
