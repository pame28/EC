ALTER PROCEDURE [dbo].[usp_LlenarBandejaECTC](@Tipo varchar(20))

AS
BEGIN
Declare @@Cantidad int;

select  @@Cantidad= count(*) from BandejaECTC;


	IF(@Tipo='Llenar')
		BEGIN
		IF(@@Cantidad<1)
			begin
			--Se inserta en la bandeja los registros a procesar en el bucle, para ser usados para generar EC
			insert into BandejaECTC(Fecha_Corte, No_Tarjeta, No_Cuenta,Correo,Estado)
			select  convert(varchar(10) ,a.Fecha_Corte ,120) Fecha_Corte, LTRIM(RTRIM(a.No_Tarjeta)) No_Tarjeta, LTRIM(RTRIM(a.No_Cuenta)) No_Cuenta, LTRIM(RTRIM(a.Correo)) Correo, Estado=2  
			FROM   HEstadoCuenta_BandejaEnvioTC  AS a   INNER JOIN dbo.FechaCarga AS fc ON a.Origen = fc.Origen AND a.Fecha_Corte = (select Fechacorte from Param_IS_ECTC where Estado=1)  
			where  (a.Correo <> '') and (a.Correo not in (select Correo from dbo.CorreosNoValidos where Estado=1))  
			and  (EXISTS (SELECT 1 FROM  dbo.EC_Detalle_Envio_Estado_Correo AS Det WHERE Det.EC_DetalleNo_Cuenta = a.No_Cuenta AND Det.Fecha_Corte = a.Fecha_Corte)     
			Or a.Pago_Contado_MN != 0     Or a.Pago_Contado_ME != 0) order by Correo
			end
		END

	IF(@Tipo='Limpiar')
		BEGIN
			--Se limpia la tabla para que pueda almacenar el siguiente corte
			truncate table BandejaECTC;

		END

END


