BEGIN
	declare @FechaCorteActual date,
			@FechaCorteNueva varchar(15),
			@FlagAmiente varchar(15),
			@Dia int,
			@Mes int,
			@Año varchar(5),
			@UltimoRegistro int,
			@Reproceso int;

	select @FechaCorteActual= FechaCorte from Param_IS_ECTC where Estado=1;
	select @FlagAmiente= E.Ambiente from EstadoCuentaHTML E;
	--Id del ultimo registro
	select @UltimoRegistro= Id from Param_IS_ECTC where Estado=1;
	--Contar si hay datos en la bandeja
	select @Reproceso=COUNT(1) FROM BandejaECTC WHERE Estado=2;

	--SI SE ESTA EJECUTANDO UN PROCESO NORMAL
	IF(@Reproceso<1)
	BEGIN
		--Si el flag es false se esta trabajando en ambiente de PRD
		if(@FlagAmiente='false')
			BEGIN
				select @Dia= DATEPART(DAY, @FechaCorteActual);
				select @Mes= DATEPART(MONTH, @FechaCorteActual);
				select @Año= DATEPART(YEAR, @FechaCorteActual);

				if (@Dia<27)
				BEGIN --Si el dia es 27
					--Si la fecha activa es corte 06
					if(@Dia=6)
						BEGIN
							--El nuevo corte activo debe de ser 10
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-'+CONVERT(varchar(3), @Mes)+'-10';
							--Actualizamos a la nueva fecha de corte que sería año-mes-10
						END
					if(@Dia=10)
						BEGIN
							--El nuevo corte activo debe de ser 18
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-'+CONVERT(varchar(3), @Mes)+'-18';
							--Actualizamos a la nueva fecha de corte que sería año-mes-18
						END
					--Si la fecha de corte activa es 18
					if(@Dia=18)
						BEGIN
							--El nuevo corte activo debe de ser 24
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-'+CONVERT(varchar(3), @Mes)+'-24';
							--Actualizamos a la nueva fecha de corte que sería año-mes-24
						END
					--Si la fecha de corte activa es 24
					if(@Dia=24)
						BEGIN
							--El nuevo corte activo debe de ser 27
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-'+CONVERT(varchar(3), @Mes)+'-27';
							--Actualizamos a la nueva fecha de corte que sería año-mes-27
						END
				END--Si el dia es menor a 27

			--Si la fecha de corte activa es 27
			if(@Dia=27)
				BEGIN
					if(@Mes<12)--Si el mes es menor a 12, no es diciembre
						BEGIN
							--select @Mes=@Mes+1;
							--El nuevo corte activo debe de ser 06
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-'+CONVERT(varchar(3), @Mes+1)+'-06';
							--Actualizamos a la nueva fecha de corte que sería año-mes+1 - 06
						END--Mes menor a 12
					if(@Mes=12)--Si el mes es igual a 12, es diciembre
						BEGIN
							select @Año=@Año+1;
							--El nuevo corte activo debe de ser 06
							select @FechaCorteNueva= CONVERT(varchar(5), @Año)+'-01-06';
							--Actualizamos a la nueva fecha de corte que sería año-01 - 06
						END--Mes igual a 12
				END--Dia igual a 27
						--Se hace el update para desctivar la fecha anterior y activar la nueva
			update Param_IS_ECTC set Estado=0 where Id=@UltimoRegistro;
			--Insertar la nueva fecha activa
			insert into Param_IS_ECTC (FechaCorte, Destinatario, Remitente, Estado) values (CONVERT(date, @FechaCorteNueva),'carlosen@banpais.hn', 'EstadoCuentaBP@banpais.hn', 1);

			END--Si el ambiente es false
	END--IF REPROCESO

END
