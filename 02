        private string BuscarCuentaVASA(Object CM, string Cuenta)
        {
            SqlConnection conn = (System.Data.SqlClient.SqlConnection)CM;

            if (conn.State != ConnectionState.Open)
            {
                conn.Open();
            }

            SqlCommand comm = new SqlCommand("select TOP(1) E.NoCuentaClaro CuentaVASA from dbo.ETarjetas E where e.NoUsuario='" + Cuenta + "'", conn);
            comm.CommandType = CommandType.Text;
            SqlDataReader sqlDataReader = comm.ExecuteReader();
            //Eliminar el objeto
            //conn.Dispose();
            comm.Dispose();

            string CuentaVASA = string.Empty;
            while (sqlDataReader.Read())
            {
                if (!string.IsNullOrEmpty(sqlDataReader["CuentaVASA"].ToString())) {
                    CuentaVASA = sqlDataReader["CuentaVASA"].ToString();
                }
            }

            //Eliminar data reader
            sqlDataReader.Dispose();

            return CuentaVASA;
        }

