                Encoding="UTF8"><![CDATA[using System;
using System.IO;
using System.Security.Cryptography;
using System.Text;

namespace ST_3ba5fe2c14ce475cbf9d979b3056e0ab.src
{  
    class EncriptacionAES
    {
        public static void EncriptarArchivo(string rutaEntrada, string rutaSalida, string keyString, string llaveiv)
        {
            //Llave Privada
            //string keyString = "qeH8b6jBD5h9i4KjMZBqYA==";

            //Se convierte el base 64 hacia byte para desencriptar
            byte[] key = Convert.FromBase64String(keyString);
            byte[] iv = Convert.FromBase64String(llaveiv);

            using (Aes aesAlg = Aes.Create())
            {
                aesAlg.Key = key;
                aesAlg.IV = iv;
                aesAlg.Mode = CipherMode.CBC;
                aesAlg.Padding = PaddingMode.PKCS7;

                using (FileStream fsEntrada = new FileStream(rutaEntrada, FileMode.Open, FileAccess.Read))
                using (FileStream fsSalida = new FileStream(rutaSalida, FileMode.Create, FileAccess.Write))
                using (CryptoStream cs = new CryptoStream(fsSalida, aesAlg.CreateEncryptor(), CryptoStreamMode.Write))
                {
                    fsEntrada.CopyTo(cs);
                }
            }
        }

        public static void DesencriptarArchivo(string rutaEntrada, string rutaSalida, string keyString, string llaveiv)
        {
            //Se convierte el base 64 hacia byte para desencriptar
            byte[] key = Convert.FromBase64String(keyString);
            byte[] iv = Convert.FromBase64String(llaveiv);

            using (Aes aesAlg = Aes.Create())
            {
                aesAlg.Key = key;
                aesAlg.IV = iv;
                aesAlg.Mode = CipherMode.CBC;
                aesAlg.Padding = PaddingMode.PKCS7;

                using (FileStream fsEntrada = new FileStream(rutaEntrada, FileMode.Open, FileAccess.Read))
                using (FileStream fsSalida = new FileStream(rutaSalida, FileMode.Create, FileAccess.Write))
                using (CryptoStream cs = new CryptoStream(fsEntrada, aesAlg.CreateDecryptor(), CryptoStreamMode.Read))
                {
                    cs.CopyTo(fsSalida);
                }
            }
        }
    }

}]]></ProjectItem>
