        /// Before returning from this method, set the value of Dts.TaskResult to indicate success or failure.
        /// To open Help, press F1.
        /// </summary>
		public void Main()
		{
			string sourceDirectory = @"" + Dts.Variables["RutaJson"].Value.ToString() + Convert.ToDateTime(Dts.Variables["FechaCorte"].Value).ToString("yyyy-MM-dd");
			string destinationDirectory = Dts.Variables["RutaJson"].Value.ToString();

			// Verifica que la carpeta de destino existe
			if (Directory.Exists(destinationDirectory))
			{
				// Obtiene todos los archivos de la carpeta de destino
				string[] files = Directory.GetFiles(destinationDirectory);
				foreach (string file in files)
				{
					// Obtiene el nombre del archivo
					string fileName = Path.GetFileName(file);
					// Define el destino del archivo
					string destFile = Path.Combine(destinationDirectory, fileName);
					// Mueve el archivo
					File.Delete(destFile);
				}
			}

			// Verifica que la carpeta de origen existe
			if (Directory.Exists(sourceDirectory))
				{
					// Obtiene todos los archivos de la carpeta de origen
					string[] files = Directory.GetFiles(sourceDirectory);
					foreach (string file in files)
					{
						// Obtiene el nombre del archivo
						string fileName = Path.GetFileName(file);
						// Define el destino del archivo
						string destFile = Path.Combine(destinationDirectory, fileName);
						// Mueve el archivo
						File.Move(file, destFile);
					}
					// Elimina la carpeta de origen si está vacía
					Directory.Delete(sourceDirectory);

                    // Elimina los archivos ya comprimidos
                    string[] filesZip = Directory.GetFiles(destinationDirectory);
                    foreach (string file in filesZip)
                    {
                        // Obtiene el nombre del archivo
                        string fileName = Path.GetFileName(file);
                    // Mueve el archivo
                    if (!fileName.ToUpper().Contains(".ZIP")) 
                    {
                        string destFile = Path.Combine(destinationDirectory, fileName);
                        File.Delete(destFile);
                    }
                }
            }

