            SqlCommand comm = new SqlCommand("update BandejaECTC set Estado='"+Estado+"' where No_Tarjeta='"+NoTarjeta+"' and No_Cuenta='"+Cuenta+"'", conn);
            comm.CommandType = CommandType.Text;
            int Result=comm.ExecuteNonQuery();
            if (Result > 1)
            {
