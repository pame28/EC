        public bool InsertReporte(string Cuenta, string NoTarjeta, string Nombre, string FechaCorte, string Estado, string Correo, Object CM, string Error = " ")
        {
            SqlConnection conn = (System.Data.SqlClient.SqlConnection)CM;

            if (conn.State != ConnectionState.Open)
            {
                conn.Open();
            }

            //Extraer el usuario y el dominio del correo
            //string[] Array = Correo.Split('@');
            //string Usuario = Array[0];
            //string Dominio = Array[1];

            //Buscar el NoCuentaVASA
            //select E.NoCuentaClaro from ETarjetas E where e.NoUsuario='5000001174384'
            string CuentaVASA = BuscarCuentaVASA(CM, Cuenta);

            if (string.IsNullOrEmpty(Nombre) | string.IsNullOrWhiteSpace(Nombre))
            {
                Error = "El campo nombre es nulo o esta vacío, no se encuentra en HEstadoCuenta_BandejaEnvioTC con cuenta: " + Cuenta;
                Nombre = " ";
            }

            if (string.IsNullOrEmpty(CuentaVASA) | string.IsNullOrWhiteSpace(CuentaVASA))
            {
                Error = "El campo NoCuentaClaro AS CuentaVASA es nulo o esta vacío, no se encuentra en dbo.ETarjetas con cuenta: " + Cuenta;
                CuentaVASA = " ";
            }

            if (string.IsNullOrEmpty(FechaCorte) | string.IsNullOrWhiteSpace(FechaCorte))
            {
                Error = "El campo FechaCorte es nulo o esta vacío, no se encuentra en ";
            }

            if (string.IsNullOrEmpty(Cuenta) | string.IsNullOrWhiteSpace(Cuenta))
            {
                Error = "El campo Cuenta es nulo o esta vacío, no se encuentra en ";
                Cuenta = " ";
            }

            if (string.IsNullOrEmpty(Correo) | string.IsNullOrWhiteSpace(Correo))
            {
                Error = "El campo Correo es nulo o esta vacío, no se encuentra en ";
                Correo = " ";
            }

            //Realizar insert
            SqlCommand comm = new SqlCommand("INSERT INTO [dbo].[HistoricoCorreosECTC] ([FechaCorte] ,[NoCuenta] ,[NoCuentaVASA] ,[Nombre] ,[CorreoCliente] ,[Estado], [Error]) VALUES (@FechaCorte ,@NoCuenta ,@NoCuentaVASA ,@Nombre ,@CorreoCliente ,@Estado, @Error)", conn);
            comm.Parameters.Add("@FechaCorte", SqlDbType.VarChar, 50).Value = FechaCorte;
            comm.Parameters.Add("@NoCuenta", SqlDbType.VarChar, 50).Value = Cuenta;
            comm.Parameters.Add("@NoCuentaVASA", SqlDbType.VarChar, 50).Value = CuentaVASA;
            comm.Parameters.Add("@Nombre", SqlDbType.VarChar, 100).Value = Nombre;
            //comm.Parameters.Add("@CorreoUsuario", SqlDbType.VarChar, 100).Value = Usuario;
            //comm.Parameters.Add("@CorreoDominio", SqlDbType.VarChar, 100).Value = Dominio;
            comm.Parameters.Add("@CorreoCliente", SqlDbType.VarChar, 100).Value = Correo;
            comm.Parameters.Add("@Estado", SqlDbType.VarChar, 100).Value = Estado;

            if (!string.IsNullOrEmpty(Error))
            {
                comm.Parameters.Add("@Error", SqlDbType.VarChar, int.MaxValue).Value = Error;
            }
            comm.CommandType = CommandType.Text;
            int Result = comm.ExecuteNonQuery();

            if (Result > 0)
            {
                return true;
            }
            else
            {
                return false;
            }
        }

        private string BuscarCuentaVASA(Object CM, string Cuenta)
        {
            SqlConnection conn = (System.Data.SqlClient.SqlConnection)CM;

            if (conn.State != ConnectionState.Open)
            {
                conn.Open();
            }

            SqlCommand comm = new SqlCommand("select TOP(1) E.NoCuentaClaro CuentaVASA from dbo.ETarjetas E where e.NoUsuario='" + Cuenta + "'", conn);
            comm.CommandType = CommandType.Text;
            SqlDataReader sqlDataReader = comm.ExecuteReader();
            //Eliminar el objeto
            //conn.Dispose();
            comm.Dispose();

            string CuentaVASA = string.Empty;
            while (sqlDataReader.Read())
            {
                if (!string.IsNullOrEmpty(sqlDataReader["CuentaVASA"].ToString()))
                {
                    CuentaVASA = sqlDataReader["CuentaVASA"].ToString();
                }
            }

            //Eliminar data reader
            sqlDataReader.Dispose();

            return CuentaVASA;
        }

